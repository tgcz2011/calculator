{
  "name": "calculator",
  "private": true,
  "version": "0.3.0.0",
  "type": "module",
  "description": "Apple-style all-platform calculator (iOS/iPadOS/macOS/Web PWA + Android/Win/Linux)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "e2e": "playwright test",
    "e2e:install": "playwright install",
    "tauri": "tauri",
    "cap:sync": "cap sync",
    "cap:ios": "cap sync ios && cap open ios",
    "cap:android": "cap sync android && cap open android",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-sql": "^2.0.0",
    "katex": "^0.16.47",
    "mathjs": "^14.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "relationship.js": "^1.2.9"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.0.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true,
    "fsevents@2.3.3": true
  }
}
